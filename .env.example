# Copy this content into a new .env.local file
AUTH_SECRET=
NEXTAUTH_URL=

# Local-only email/password (development / NODE_ENV=development only). Used when you open the app on localhost (e.g. http://localhost:3000/login). Never set in production.
# LOCAL_AUTH_TEST_EMAIL=
# LOCAL_AUTH_TEST_PASSWORD=
# Optional stable Firestore user id for this test account (default: local-test-user).
# LOCAL_AUTH_TEST_USER_ID=

# Firebase Server Configuration
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_STORAGE_BUCKET=

# Firebase Client Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Frida Agent Builder (server-side: Load Agent list from by-deployment API)
FRIDA_AGENT_BUILDER_BASE_URL=
FRIDA_AGENT_BUILDER_API_KEY=

# MCP (SSE): optional fallbacks — Load Agent should supply url + x-api-key + DB headers
# (e.g. x-db-url) in mcps.mcpServers when your MCP server needs them.
# MCP_SSE_URL / MCP_X_API_KEY: used only if the agent omits url or x-api-key.
# MCP_SSE_URL must be HTTPS and a public-safe host (see lib/mcp/safe-mcp-remote-url.ts).
# MCP_STRIP_DB_HEADERS=true: remove x-db-* from agent payload (use only if DB is set on MCP container).
MCP_SSE_URL=
MCP_X_API_KEY=
MCP_STRIP_DB_HEADERS=

# OpenAI-compatible API configuration
# Use either OPENAI_COMPATIBLE_API or LLM_API_BASE_URL.
OPENAI_COMPATIBLE_API=
LLM_API_BASE_URL=

# Use either LLMOPS_API_KEY, LLM_API_KEY, or OPENAI_API_KEY.
LLMOPS_API_KEY=
LLM_API_KEY=
OPENAI_API_KEY=

# Optional model overrides.
# If unset, CHAT_MODEL / REASONING_MODEL / TITLE_MODEL / ARTIFACT_MODEL
# fall back to LLM_MODEL_NAME (or gpt-4o-mini by default).
LLM_MODEL_NAME=
CHAT_MODEL=
REASONING_MODEL=
TITLE_MODEL=
ARTIFACT_MODEL=
EMBEDDING_MODEL=

# E2B Desktop (computer use): required when an agent enables the Frida custom tool type "computer-use".
# Get a key at https://e2b.dev/docs
E2B_API_KEY=
# Optional: set to "true" to disable desktop tools even if the agent has computer-use enabled.
# E2B_DESKTOP_DISABLED=

# Debugging (optional, local dev)
# DEBUG_OPENAI_COMPATIBLE=true — log OpenAI-compatible HTTP request/response bodies (see lib/ai/providers.ts).
# DEBUG_CHAT_STREAM_CHUNKS=true — log each streamText chunk (text-delta, reasoning-delta, tool-*, …) in POST /api/chat (server terminal).
# DEBUG_CHAT_TOOLS — tool logs in POST /api/chat: in `next dev`, verbose logs are ON unless you set DEBUG_CHAT_TOOLS=false. In production, set DEBUG_CHAT_TOOLS=true to enable. Warnings (⚠️ [chat-tools]) for failed tool results are always logged when the model returns an error-shaped tool output.

# Anthropic extensions passthrough (OpenAI-compatible backend contract).
# Applies only when the resolved model id contains "claude".
# Code execution is enabled by default for Claude. Set to "false" to disable.
ANTHROPIC_ENABLE_CODE_EXECUTION=
# Optional override list. If empty, defaults to: pptx, docx, pdf, xlsx.
# Comma-separated list. Supports optional @version, e.g. "pdf@latest,pptx".
ANTHROPIC_SKILLS=
# Optional comma-separated extra Anthropic betas to forward.
ANTHROPIC_EXTENSION_BETAS=

# --- Anthropic context management (Frida → gateway → Anthropic) ---
# Frida builds `providerOptions.openaiCompatible.anthropicExtensions.contextManagement` from these.
# The OpenAI-compatible gateway (openai-ai-sdk) can STRIP the whole blob if its own
# ANTHROPIC_ENABLE_COMPACTION=false — enable compaction in BOTH places for it to take effect.
ANTHROPIC_ENABLE_COMPACTION=
# Minimum trigger is 50k input tokens (Frida clamps); optional higher threshold.
ANTHROPIC_COMPACTION_THRESHOLD=
# Optional free-text compaction instructions forwarded to Anthropic.
ANTHROPIC_COMPACTION_INSTRUCTIONS=
ANTHROPIC_ENABLE_CLEAR_THINKING=
ANTHROPIC_CLEAR_THINKING_KEEP=
ANTHROPIC_ENABLE_CLEAR_TOOL_USES=
ANTHROPIC_CLEAR_TOOL_USES_TRIGGER=
ANTHROPIC_CLEAR_TOOL_USES_KEEP=
ANTHROPIC_CLEAR_TOOL_USES_CLEAR_AT_LEAST=
# Comma-separated tool name substrings to exclude from clearing.
ANTHROPIC_CLEAR_TOOL_USES_EXCLUDE=
ANTHROPIC_ENABLE_THINKING=
ANTHROPIC_THINKING_EFFORT=

# --- Gateway (openai-ai-sdk) env to align with the matrix above ---
# ANTHROPIC_ENABLE_COMPACTION — must not strip contextManagement if Frida sends it.
# ANTHROPIC_ENABLE_THINKING — gateway may strip thinking config when false.

# --- Token / context tuning (Frida) ---
# Rough JSON log of message count, part histogram, char/token estimate before streamText.
DEBUG_CHAT_CONTEXT_SIZE=
# Application-level stub of older allowlisted tool outputs (DB unchanged). Default allowlist in code unless overridden.
CHAT_MICROCOMPACT_ENABLED=
CHAT_MICROCOMPACT_KEEP_MESSAGES=
# Comma-separated substrings; when set, replaces built-in allowlist for microcompact.
CHAT_MICROCOMPACT_TOOL_SUBSTRINGS=
# When true, first stream attempt uses a draining merge so read errors propagate; one retry with aggressive trim on overflow-like errors.
CHAT_RETRY_ON_CONTEXT_OVERFLOW=
# Caps MCP tool bullet list in system prompt (see lib/ai/prompts.ts).
SYSTEM_PROMPT_DENSITY=

# --- Manual thread compact (Phase 5) ---
# ENABLE_MANUAL_THREAD_COMPACT=true exposes POST /api/chat/compact (destructive: deletes old messages).
ENABLE_MANUAL_THREAD_COMPACT=
COMPACT_KEEP_RECENT_MESSAGES=
# Logical model id for summary (defaults to title-model).
COMPACT_SUMMARY_MODEL=
